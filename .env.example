# Скопируйте в .env (для docker compose) и в backend/.env (для локального запуска без Docker).
# Никогда не коммитьте заполненный файл.

SECRET_KEY=
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=steinsgate
DB_USER=steinsgate
DB_PASSWORD=
# DB_HOST/DB_PORT для локального запуска; в compose перекрываются значениями сервиса db
DB_HOST=127.0.0.1
DB_PORT=5432

EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
