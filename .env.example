# Скопируйте в .env в корне репозитория: его читают и docker compose, и локальный запуск.
# Никогда не коммитьте заполненный файл.

SECRET_KEY=
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
# Host port of the frontend container. PostgreSQL and Redis are not published.
APP_PORT=4173

DB_NAME=steinsgate
DB_USER=steinsgate
DB_PASSWORD=
# DB_HOST/DB_PORT для локального запуска; в compose перекрываются значениями сервиса db
DB_HOST=127.0.0.1
DB_PORT=5432

EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Redis для троттлинга, блокировок и кэша; в compose задается сервисом
# REDIS_URL=redis://127.0.0.1:6379/0
